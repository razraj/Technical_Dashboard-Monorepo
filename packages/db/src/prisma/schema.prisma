generator client {
  provider        = "prisma-client-js"
  output          = "../generated/client"
  binaryTargets   = ["native"]
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pg_trgm]
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum TimesheetStatus {
  COMPLETED
  INCOMPLETE
  MISSING
}

enum UserRole {
  EMPLOYEE
  PROJECT_MANAGER
}

enum TaskType {
  FIX
  FEATURE
  RESEARCH
  OTHER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  BLOCKED
}

enum ProjectRole {
  OWNER
  MEMBER
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id       String   @id @default(uuid())
  email    String   @unique @db.VarChar(255) // RFC 5321 max
  username String   @unique @db.VarChar(30)
  role     UserRole @default(EMPLOYEE)

  // nullable — null when user authenticates via OAuth instead of password
  password String?

  firstName  String?
  lastName   String?
  profilePic String?

  // Email verification
  emailVerified          DateTime?
  emailVerificationToken String?   @unique
  emailVerificationExp   DateTime?

  // Session tokens — stored hashed; expire on logout or rotation
  refreshToken    String?
  refreshTokenExp DateTime?

  // Password reset
  resetToken    String? @unique
  resetTokenExp DateTime?

  isDeleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activityLogs       ActivityLog[]   @relation("UserActivityLogs")
  timesheets         Timesheet[]
  createdProjects    Project[]       @relation("ProjectCreator")
  projectMemberships ProjectMember[]
  assignedTasks      Task[]          @relation("TaskAssignee")
  createdTasks       Task[]          @relation("TaskCreator")

  // No standalone @@index([isDeleted]) — boolean fields have near-zero cardinality
  // in PostgreSQL and are ignored by the planner without a selective leading column.
}

model Project {
  id          String          @id @default(uuid())
  name        String          @db.VarChar(100)
  description String?
  color       String?         @db.VarChar(9) // hex: #RGB / #RRGGBB / #RRGGBBAA
  createdById String
  isDeleted   Boolean         @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy User            @relation("ProjectCreator", fields: [createdById], references: [id], onDelete: Cascade)
  members   ProjectMember[]
  tasks     Task[]

  @@index([createdById])
  // Trigram GIN index — powers project search/autocomplete when creating a task
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin)
}

model ProjectMember {
  id        String      @id @default(uuid())
  projectId String
  userId    String
  role      ProjectRole @default(MEMBER)
  joinedAt  DateTime    @default(now())
  updatedAt DateTime    @updatedAt // tracks role changes (e.g. MEMBER → OWNER)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
}

model Task {
  id             String     @id @default(uuid())
  projectId      String
  title          String     @db.VarChar(255)
  description    String?
  type           TaskType
  status         TaskStatus @default(TODO)
  estimatedHours Decimal?   @db.Decimal(6, 2)
  // Defaults to createdById in app logic; nullable so the field can be cleared
  // if the assigned user is removed from the project.
  assignedToId   String?
  createdById    String
  dueDate        DateTime?  @db.Date
  isDeleted      Boolean    @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project    Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedTo User?            @relation("TaskAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy  User             @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Restrict)
  entries    TimesheetEntry[]

  @@index([projectId])
  // Composite [assignedToId, status] — "show me my active tasks" (primary employee view)
  @@index([assignedToId, status])
  // Composite [createdById, status] — "tasks I created with status X" (PM / employee view)
  @@index([createdById, status])
  // Composite [projectId, status] — "open tasks in this project" (project detail view)
  @@index([projectId, status])
}

model Timesheet {
  id     String @id @default(uuid())
  userId String

  // Sequential per-user counter; used for display ordering and backward compatibility.
  // @@unique([userId, periodStart]) is the canonical uniqueness key for upserts.
  sequenceNumber Int

  status TimesheetStatus @default(MISSING)
  title  String          @db.VarChar(100) // e.g. "Week of 2026-05-26"
  notes  String?

  periodStart DateTime @db.Date
  periodEnd   DateTime @db.Date

  // Denormalised rollup columns — recomputed by recomputeRollups() on every entry change.
  totalHours    Decimal @default(0) @db.Decimal(6, 2)
  regularHours  Decimal @default(0) @db.Decimal(6, 2)
  overtimeHours Decimal @default(0) @db.Decimal(6, 2)

  submittedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries TimesheetEntry[]

  @@unique([userId, sequenceNumber])
  @@unique([userId, periodStart])
  // [userId, periodStart] covers single-column userId lookups via index prefix — no
  // separate @@index([userId]) needed.
  @@index([userId, periodStart])
  // [userId, status] — "show my MISSING/INCOMPLETE weeks" and PM dashboard queries
  @@index([userId, status])
}

model TimesheetEntry {
  id          String   @id @default(uuid())
  timesheetId String
  taskId      String
  workDate    DateTime @db.Date
  // Per-block hours; Decimal(4,2) supports up to 99.99h — sufficient for a single
  // work block (max 24h per day in practice).
  hours       Decimal  @db.Decimal(4, 2)

  startTime   DateTime?
  endTime     DateTime?
  isOvertime  Boolean   @default(false)
  // Day-specific note; intentionally separate from Task.description so the
  // user can record what they actually did that day.
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  timesheet Timesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)
  // Restrict prevents hard-deleting a task that has logged hours; use Task.isDeleted instead.
  task      Task      @relation(fields: [taskId], references: [id], onDelete: Restrict)

  // Composite covers both "all entries for a timesheet" and "entries on a specific date"
  @@index([timesheetId, workDate])
  // Needed for FK constraint checks (Restrict) and "all entries for a task" queries
  @@index([taskId])
}

model ActivityLog {
  id     BigInt @id @default(autoincrement()) // BigInt for high-volume inserts; no UUID overhead
  userId String
  // Free-form type string (e.g. "LOGIN", "TASK_CREATED"). Kept as String rather than
  // an enum so new event types can be added without schema migrations.
  type        String
  description String?

  // No updatedAt — activity logs are immutable; records are never updated after creation.
  createdAt DateTime @default(now())

  user User @relation("UserActivityLogs", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  // [userId, createdAt] — "recent activity for user" (paginated by time)
  @@index([userId, createdAt])
  // [type] — filter or aggregate events by type (admin/PM dashboard)
  @@index([type])
}

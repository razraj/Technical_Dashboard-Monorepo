// =============================================================================
// TenT Technical Dashboard — Prisma schema
// -----------------------------------------------------------------------------
// Data model for users, projects, planned work (tasks) and logged work
// (timesheet entries). The connection URL is NOT declared here on purpose: it
// is injected at runtime from `process.env.DATABASE_URL` via `prisma.config.ts`
// (see `packages/db/prisma.config.ts`), so the schema stays environment-free.
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  // Emit the client into the package's local `generated/` dir so it can be
  // re-exported by `@repo/db` without leaking into other workspaces.
  output          = "../generated/client"
  binaryTargets   = ["native"]
  // Required so the `pg_trgm` extension below can be declared in-schema.
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  // pg_trgm powers trigram-based fuzzy text search (e.g. ILIKE / similarity on
  // names and descriptions). The extension is enabled at the DB level here;
  // add GIN/GiST trigram indexes per-column when a search query needs them.
  extensions = [pg_trgm]
}

// --- ENUMS -------------------------------------------------------------------

/// Authorization tier for a user. Drives access control across the app.
enum Role {
  ADMIN // Full access, including user management.
  MANAGER // Owns projects and reviews team members' work.
  EMPLOYEE // Default role; logs time and works assigned tasks.
}

/// Lifecycle of a planned unit of work (a Task), as shown on the board UI.
enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  COMPLETED
}

// --- MODELS ------------------------------------------------------------------

/// Audit trail of notable user actions (login, edits, etc.).
model ActivityLog {
  // BigInt autoincrement: high-volume, append-only log where a compact,
  // monotonically increasing key is preferable to a UUID.
  id          BigInt  @id @default(autoincrement())
  description String?
  type        String // Machine-readable event type, e.g. "AUTH_LOGIN".
  userId      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Cascade: logs are meaningless without their user, so hard-deleting a user
  // removes their logs. (Note: User uses soft delete, so this rarely fires.)
  user User @relation("UserActivityLogs", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// An application user (employee, manager, or admin).
model User {
  id         String  @id @default(uuid()) // Stable external identifier.
  email      String  @unique // Unique => already backed by an index.
  password   String? // Null for SSO/invited-but-not-activated accounts.
  username   String  @unique
  firstName  String?
  lastName   String?
  profilePic String?

  // --- App logic & timesheet UI requirements ---
  role           Role  @default(EMPLOYEE)
  weeklyCapacity Float @default(40) // Contracted hours/week; used for utilization.

  // --- Auth tokens ---
  // Verification, password-reset and refresh tokens are stored hashed/opaque.
  // `@unique` on token columns lets us look a user up directly by token.
  emailVerified          DateTime? // Set once the email link is confirmed.
  emailVerificationToken String?   @unique
  emailVerificationExp   DateTime?
  refreshToken           String?
  refreshTokenExp        DateTime?
  resetToken             String?   @unique
  resetTokenExp          DateTime?

  // Soft delete: users are flagged rather than removed to preserve the
  // integrity of their historical tasks and timesheet entries.
  isDeleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // --- Relations ---
  activityLogs    ActivityLog[]    @relation("UserActivityLogs")
  timesheets      TimesheetEntry[]
  managedProjects Project[]        @relation("ProjectManager")
  createdTasks    Task[]           @relation("TaskCreator")
  assignedTasks   Task[]           @relation("TaskAssignee")
  // NOTE: no `@@index([email])` here — `email @unique` already creates a unique
  // index that Postgres uses for equality lookups, so a second index would be
  // redundant and add write overhead.

  // Speeds up the common "list active users" filter.
  @@index([isDeleted])
}

/// A project that groups tasks and timesheet entries, owned by a manager.
model Project {
  id          String  @id @default(uuid())
  name        String
  description String?
  managerId   String

  // Soft delete: `deletedAt` is null while active, timestamped when removed.
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // --- Relations ---
  // No onDelete override => Prisma default `Restrict`: a manager cannot be
  // hard-deleted while they still own projects.
  manager       User             @relation("ProjectManager", fields: [managerId], references: [id])
  tasks         Task[]
  timesheetLogs TimesheetEntry[] // Time can be booked directly to a project.

  @@index([managerId])
}

/// A planned unit of work assigned by managers or employees.
model Task {
  id          String     @id @default(uuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)

  estimatedHours Float     @default(0)
  // `@db.Date` stores a calendar date with no time component / timezone.
  startDate      DateTime? @db.Date
  dueDate        DateTime? @db.Date

  projectId  String
  creatorId  String
  assigneeId String? // Unassigned tasks are allowed (sit in the backlog).

  // Soft delete (see Project.deletedAt).
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // --- Relations ---
  project       Project          @relation(fields: [projectId], references: [id])
  creator       User             @relation("TaskCreator", fields: [creatorId], references: [id])
  assignee      User?            @relation("TaskAssignee", fields: [assigneeId], references: [id])
  timesheetLogs TimesheetEntry[]

  @@index([projectId])
  @@index([assigneeId]) // "My tasks" lookups.
  @@index([creatorId]) // FK index: Postgres does not auto-index FKs.
  @@index([dueDate]) // Due-date sorting / overdue queries.
}

/// Actual logged time, created via the "Add New Entry" timesheet UI.
model TimesheetEntry {
  id String @id @default(uuid())

  // --- Maps to the UI modal fields ---
  date        DateTime @db.Date // Day the work was performed.
  hours       Float // Decimal hours, e.g. 1.5.
  workType    String // e.g. "Bug fixes", "Development".
  description String   @db.Text // Free-form notes; @db.Text avoids varchar limits.

  userId    String
  projectId String
  taskId    String? // Optional: links an ad-hoc entry to a planned task.

  // Soft delete (see Project.deletedAt).
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // --- Relations ---
  user    User    @relation(fields: [userId], references: [id])
  project Project @relation(fields: [projectId], references: [id])
  task    Task?   @relation(fields: [taskId], references: [id])

  @@index([userId, date]) // Per-user date-range timesheet views.
  @@index([projectId])
  @@index([taskId]) // FK index for task-rollup queries.
}

{
    "name": "TenT_FS",
    "private": true,
    "version": "1.0.0",
    "scripts": {
        "build": "turbo run build --force",
        "dev": "turbo run dev",
        "dev:backend": "turbo run dev --filter=backend",
        "clear": "turbo run clear && rm -rf .next .turbo node_modules",
        "env:cp": "cp .env ./apps/backend/.env && cp .env ./apps/web/.env && cp .env ./packages/db/.env",
        "lint": "turbo run lint",
        "format": "prettier --write \"apps/**/*.{json,js,ts,tsx,md}\" \"packages/**/*.{json,js,ts,tsx,md}\"",
        "check-types": "turbo run check-types"
    },
    "devDependencies": {
        "prettier": "^3.7.4",
        "prisma": "^7.8.0",
        "turbo": "^2.9.15",
        "typescript": "5.9.2"
    },
    "engines": {
        "node": ">=22.13.0"
    },
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "packageManager": "yarn@4.15.0"
}

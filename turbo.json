{
    "$schema": "https://turborepo.dev/schema.json",
    "futureFlags": {
        "globalConfiguration": true
    },
    "globalEnv": [
        "DATABASE_HOST",
        "DATABASE_URL",
        "JWT_SECRET",
        "DEFAULT_PASSWORD",
        "SMTP_SERVER_HOST",
        "SMTP_SERVER_USERNAME",
        "SMTP_SERVER_PASSWORD",
        "SMTP_FROM_EMAIL",
        "SITE_MAIL_RECIEVER",
        "NODE_ENV",
        "RESEND_API_KEY"
    ],
    "global": {
        "ui": "tui",
        "inputs": [".env"],
        "passThroughEnv": [
            "DATABASE_HOST",
            "DATABASE_URL",
            "JWT_SECRET",
            "DEFAULT_PASSWORD",
            "SMTP_SERVER_HOST",
            "SMTP_SERVER_USERNAME",
            "SMTP_SERVER_PASSWORD",
            "SMTP_FROM_EMAIL",
            "SITE_MAIL_RECIEVER",
            "RESEND_API_KEY"
        ],
        "env": [
            "DATABASE_HOST",
            "DATABASE_URL",
            "JWT_SECRET",
            "DEFAULT_PASSWORD",
            "SMTP_SERVER_HOST",
            "SMTP_SERVER_USERNAME",
            "SMTP_SERVER_PASSWORD",
            "SMTP_FROM_EMAIL",
            "SITE_MAIL_RECIEVER",
            "NODE_ENV",
            "RESEND_API_KEY"
        ],
        "envMode": "loose"
    },
    "tasks": {
        "clear": {
            "dependsOn": ["^clear"],
            "cache": false,
            "description": "Cleans the project"
        },
        "build": {
            "dependsOn": ["^build", "^db:generate"],
            "inputs": ["$TURBO_DEFAULT$", ".env*"],
            "outputs": [".next/**", "!.next/cache/**"],
            "description": "Compiles the application for production deployment"
        },
        "generate": {
            "dependsOn": ["^generate", "^db:generate"],
            "inputs": ["$TURBO_DEFAULT$"]
        },
        "db:generate": {
            "cache": false,
            "env": ["DATABASE_URL"],
            "dependsOn": ["^db:generate"],
            "inputs": ["$TURBO_DEFAULT$", ".env*"]
        },
        "lint": {
            "dependsOn": ["^lint"]
        },
        "check-types": {
            "dependsOn": ["^check-types"]
        },
        "dev": {
            "cache": false,
            "persistent": true,
            "description": "Runs the application in development mode"
        }
    }
}
